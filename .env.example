# --- Runtime ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
TRUST_PROXY_HOPS=1

# --- Database (Neon serverless PostgreSQL) ---
# Copy this file to .env.local and paste your Neon connection string. Both the
# app (dev/test) and the Prisma CLI auto-load .env.local; no local Postgres or
# Docker is needed for development. Production injects DATABASE_URL as a runtime
# container env instead.
DATABASE_URL=postgresql://USER:PASSWORD@EP-xxxx.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_POOL_MAX=5

# --- App JWT (custom auth) ---
# HS256 secret to start; RS256 (key pair) is the documented future option.
JWT_SECRET=change-me-to-a-long-random-secret-at-least-16-chars
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# --- Google Sign-In verification ---
# Comma-separated list of accepted Google OAuth client IDs (audience).
GOOGLE_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com,your-ios-client-id.apps.googleusercontent.com

# --- Deepseek (AI categorization / planning / chat) ---
# Optional: when DEEPSEEK_API_KEY is absent the gateway degrades to a no-op
# (imports still persist, just uncategorized), so local dev/tests run without it.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Stripe (subscription billing) ---
# Empty by default so local dev/tests boot without real keys; the Stripe gateway
# degrades (throws a typed error) when the secret is empty. Set all four in prod.
# Prices are per-seat recurring prices created in the Stripe dashboard (BRL).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_ANNUAL=

# --- CORS (homolog/prod allowlist, comma-separated; dev reflects origin) ---
CORS_ALLOWED_ORIGINS=

# --- Rate limit ---
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000
