{
  "name": "finance-back",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "dev": "docker compose -f docker/docker-compose.yml up -d && pnpm dev:native",
    "dev:db": "docker compose -f docker/docker-compose.yml up -d postgres",
    "dev:down": "docker compose -f docker/docker-compose.yml down",
    "dev:reset": "docker compose -f docker/docker-compose.yml down -v",
    "dev:native": "tsx watch --clear-screen=false src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "lint": "biome check .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx scripts/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "postinstall": "prisma generate"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "cpu-features",
      "prisma",
      "protobufjs",
      "ssh2"
    ]
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/jwt": "^10.2.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.8.0",
    "@fastify/swagger-ui": "^6.1.0",
    "@prisma/client": "^6.19.3",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "fastify-type-provider-zod": "^7.0.0",
    "google-auth-library": "^10.9.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "stripe": "^22.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "prisma": "^6.19.3",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "~5.9.0",
    "vitest": "^4.1.10"
  }
}
